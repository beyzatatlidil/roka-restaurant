<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reservation | Roka Restaurant</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/chatbot.css" />
</head>

<body>
  <nav class="navbar">
    <div class="container navbar-inner">
      <div class="logo">Roka <span>Restaurant</span></div>

      <div class="nav-links">
        <a href="/">Home</a>
        <a href="/menu">Menu</a>
        <a href="/reservation">Reservation</a>
        <a href="/my-orders">My Orders</a>
        <a href="/my-reservations">My Reservations</a>
        <a href="/login">Login</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero" style="padding-bottom: 20px;">
      <div class="hero-grid">
        <div class="hero-text">
          <h1>Reserve Your Table In Minutes.</h1>
          <p>
            Enjoy a modern reservation experience with quick booking, special
            requests, and premium dining comfort.
          </p>

          <div class="hero-stats">
            <div class="stat-card">
              <h3>Easy</h3>
              <p>Booking Flow</p>
            </div>

            <div class="stat-card">
              <h3>Fast</h3>
              <p>Confirmation</p>
            </div>

            <div class="stat-card">
              <h3>Premium</h3>
              <p>Dining Experience</p>
            </div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-panel" style="
              background:
                linear-gradient(rgba(12, 14, 18, 0.28), rgba(12, 14, 18, 0.58)),
                url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1200&q=80')
                center/cover no-repeat;
            ">
            <div class="hero-overlay-card">
              <span class="hero-badge">Table Booking</span>
              <h4>Elegant Reservation Experience</h4>
              <p>
                Choose your date, time, guest count, and special request in one clean form.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-header" style="margin-top: 10px;">
      <div>
        <h2>Book a Table</h2>
        <p>Fill in the details below to create your reservation.</p>
      </div>
    </section>

    <section class="reservation-layout">
      <div class="reservation-card">
        <div id="reservationMessage"></div>

        <form class="reservation-form" id="reservationForm">
          <div class="form-grid">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your Name" required />
            </div>

            <div class="form-group">
              <label for="date">Date</label>
              <input type="date" id="date" name="date" required />
            </div>

            <div class="form-group">
              <label for="time">Time</label>
              <input type="time" id="time" name="time" required />
            </div>

            <div class="form-group">
              <label for="guests">Guests</label>
              <input type="number" id="guests" name="guests" min="1" max="12" placeholder="Enter guest count"
                required />
            </div>

            <div class="form-group">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" placeholder="05xx xxx xx xx" required />
            </div>
          </div>

          <div class="form-group" style="margin-top: 18px;">
            <label for="specialRequest">Special Request</label>
            <textarea id="specialRequest" name="specialRequest" rows="5"
              placeholder="Birthday table, quiet area, window seat..."></textarea>
          </div>

          <div style="margin-top: 22px; display: flex; gap: 12px; flex-wrap: wrap;">
            <button type="submit" class="btn btn-primary">Create Reservation</button>
            <a href="/" class="btn btn-secondary">Back to Menu</a>
          </div>
        </form>
      </div>

      <div class="reservation-side">
        <div class="info-box">
          <h4>Reservation Notes</h4>
          <p>
            Please arrive on time for your reservation. For large groups, mention details in special request.
          </p>
        </div>

        <div class="info-box">
          <h4>Opening Hours</h4>
          <p>
            Monday - Friday: 10:00 - 23:00<br />
            Saturday - Sunday: 12:00 - 00:00
          </p>
        </div>

        <div class="info-box">
          <h4>Contact</h4>
          <p>
            Phone: +90 555 123 45 67<br />
            Email: info@rokarestaurant.com
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>© 2026 Roka Restaurant — Premium reservation experience.</p>
    </div>
  </footer>

  <script>
    const reservationForm = document.getElementById("reservationForm");
    const reservationMessage = document.getElementById("reservationMessage");
    const dateInput = document.getElementById("date");

    if (dateInput) {
      const today = new Date().toISOString().split("T")[0];
      dateInput.min = today;
    }

    function showMessage(type, text) {
      reservationMessage.innerHTML = `
        <div class="alert ${type === "success" ? "success-alert" : "error-alert"}">
          ${text}
        </div>
      `;
    }

    reservationForm.addEventListener("submit", async function (e) {
      e.preventDefault();

      const data = {
        name: document.getElementById("name").value.trim(),
        date: document.getElementById("date").value,
        time: document.getElementById("time").value,
        guests: Number(document.getElementById("guests").value),
        phone: document.getElementById("phone").value.trim(),
        specialRequest: document.getElementById("specialRequest").value.trim(),
      };

      if (!data.name || !data.date || !data.time || !data.guests || !data.phone) {
        showMessage("error", "Please fill in all required fields.");
        return;
      }

      try {
        const response = await fetch("/api/reservations", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        let result;
        try {
          result = await response.json();
        } catch (jsonError) {
          throw new Error("Server returned invalid JSON.");
        }

        if (!response.ok) {
          throw new Error(result.message || result.error || "Reservation could not be created.");
        }

        showMessage(
          "success",
          `Reservation created successfully. Your code: ${result.reservation.reservationCode}`
        );

        reservationForm.reset();

        if (dateInput) {
          const today = new Date().toISOString().split("T")[0];
          dateInput.min = today;
        }
      } catch (error) {
        console.error("RESERVATION ERROR:", error);
        showMessage("error", error.message || "Reservation could not be created.");
      }
    });
  </script>
</body>

</html>