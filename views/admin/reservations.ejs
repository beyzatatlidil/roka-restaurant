<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin | Reservations</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f3f4f6;
      color: #111827;
    }

    /* SIDEBAR */
    .sidebar {
      width: 240px;
      height: 100vh;
      background: #1e293b;
      color: white;
      position: fixed;
      padding: 30px 20px;
    }

    .sidebar h2 {
      font-size: 22px;
      margin-bottom: 30px;
    }

    .sidebar a {
      display: block;
      padding: 12px;
      color: #cbd5e1;
      text-decoration: none;
      border-radius: 6px;
      margin-bottom: 8px;
    }

    .sidebar a.active {
      background: #3b82f6;
      color: white;
    }

    .sidebar a:hover {
      background: #334155;
    }

    /* MAIN */
    .main {
      margin-left: 240px;
      padding: 30px;
    }

    /* HEADER */
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 25px;
    }

    .topbar h1 {
      font-size: 28px;
    }

    .topbar p {
      color: #6b7280;
      font-size: 14px;
      margin-top: 5px;
    }

    .admin-user {
      font-weight: 600;
      font-size: 14px;
    }

    /* TABLE CARD */
    .table-card {
      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 10px;
      overflow: hidden;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th,
    td {
      padding: 14px;
      border-bottom: 1px solid #e5e7eb;
      font-size: 14px;
    }

    thead {
      background: #f9fafb;
    }

    tbody tr:hover {
      background: #f9fafb;
    }

    /* EMPTY */
    .empty-box {
      padding: 40px;
      text-align: center;
      color: #6b7280;
    }
  </style>
</head>

<body>

  <aside class="sidebar">
    <h2>ROKA Control</h2>
    <a href="/admin">Dashboard</a>
    <a href="/admin/orders">Orders</a>
    <a href="/admin/reservations" class="active">Reservations</a>
    <a href="/admin/menu">Menu</a>
  </aside>

  <main class="main">

    <div class="topbar">
      <div>
        <h1>Reservations</h1>
        <p>Manage customer reservations.</p>
      </div>

      <div class="admin-user">
        Beyza Tatlıdil • Online
      </div>
    </div>

    <div class="table-card">

      <% if (!reservations || reservations.length===0) { %>
        <div class="empty-box">
          <h3>No reservations found</h3>
          <p>New reservations will appear here.</p>
        </div>
        <% } else { %>

          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Phone</th>
                <th>Date</th>
                <th>Time</th>
              </tr>
            </thead>

            <tbody>
              <% reservations.forEach(reservation=> { %>
                <tr>
                  <td>
                    <%= reservation.name %>
                  </td>
                  <td>
                    <%= reservation.phone %>
                  </td>
                  <td>
                    <%= reservation.date %>
                  </td>
                  <td>
                    <%= reservation.time %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>

          <% } %>

    </div>

  </main>

</body>

</html>