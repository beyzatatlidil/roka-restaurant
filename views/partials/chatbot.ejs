    font-family: 'Segoe UI', sans-serif;
  }

  /* HEADER */
  .chat-header {
    background: #111827;
    color: white;
    padding: 14px;
    font-size: 16px;
    font-weight: bold;
    display: flex;
    justify-content: space-between;
  }

  /* MESSAGES */
  .chat-messages {
    flex: 1;
    padding: 14px;
    overflow-y: auto;
  }

  /* MESSAGE BUBBLES */
  .msg {
    max-width: 80%;
    padding: 12px 14px;
    border-radius: 14px;
    margin: 8px 0;
    font-size: 15px;
    line-height: 1.5;
    word-wrap: break-word;
  }

  .user {
    background: #f59e0b;
    color: black;
    margin-left: auto;
  }

  .bot {
    background: #1f2937;
    color: white;
  }

  /* INPUT */
  .chat-input {
    display: flex;
    border-top: 1px solid #222;
  }

  .chat-input textarea {
    flex: 1;
    padding: 12px;
    border: none;
    outline: none;
    resize: none;
    background: #0b0f1a;
