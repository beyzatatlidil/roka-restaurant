<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>

  <style>
    body{
      font-family:Arial;
      background:#f5f5f5;
    }

    .container{
      max-width:1000px;
      margin:40px auto;
      display:grid;
      grid-template-columns:2fr 1fr;
      gap:20px;
    }

    .box{
      background:white;
      padding:25px;
      border-radius:12px;
      box-shadow:0 5px 20px rgba(0,0,0,0.08);
    }

    input, textarea, select{
      width:100%;
      padding:10px;
      margin-bottom:12px;
      border-radius:8px;
      border:1px solid #ddd;
    }

    button{
      width:100%;
      padding:12px;
      background:#f59e0b;
      border:none;
      border-radius:8px;
      font-weight:bold;
      cursor:pointer;
    }
  </style>
</head>

<body>

<div class="container">

  <!-- LEFT -->
  <div class="box">
    <h2>Customer Info</h2>

    <input id="name" placeholder="Full Name" />
    <input id="phone" placeholder="Phone" />
    <textarea id="address" placeholder="Address"></textarea>

    <h3>Payment Method</h3>
    <select id="payment">
      <option>Cash on Delivery</option>
      <option>Card on Delivery</option>
      <option>Demo Online Payment</option>
    </select>
  </div>

  <!-- RIGHT -->
  <div class="box">
    <h2>Order Summary</h2>

    <div id="summary"></div>

    <h3 id="total"></h3>

    <button onclick="placeOrder()">Place Order</button>
  </div>

</div>

<script>
  // LOGIN GUARD (PRO LEVEL)
(function () {
  const token = localStorage.getItem("token");

  if (!token || token === "undefined" || token === "null") {
    alert("Sipariş vermek için giriş yapmalısınız");
    window.location.href = "/login?redirect=/checkout";
  }
})();
  const CART_KEY = "rokaCart";
  const API_URL = "/api/orders";

  function getToken() {
    const token = localStorage.getItem("token");
    if (!token || token === "undefined" || token === "null") {
      return null;
    }
    return token;
  }

  function getCart() {
    try {
      return JSON.parse(localStorage.getItem(CART_KEY)) || [];
    } catch (error) {
      localStorage.removeItem(CART_KEY);
      return [];
    }
  }

  function loadSummary(){
    const cart = getCart();

    if(cart.length === 0){
      document.getElementById("summary").innerHTML = "<p>Your cart is empty</p>";
      document.getElementById("total").innerText = "";
      return;
    }

    let subtotal = 0;

    document.getElementById("summary").innerHTML = cart.map(item=>{
      const qty = Number(item.qty || item.quantity || 1);
      const price = Number(item.price) || 0;
      const itemTotal = price * qty;
      subtotal += itemTotal;

      return `
        <div style="display:flex; justify-content:space-between; margin-bottom:8px;">
          <span>${item.name} x ${qty}</span>
          <span>${itemTotal} TL</span>
        </div>
      `;
    }).join("");

    const deliveryFee = 40;
    const serviceFee = 10;
    const total = subtotal + deliveryFee + serviceFee;

    document.getElementById("summary").innerHTML += `
      <hr style="margin:10px 0">
      <p>Subtotal: ${subtotal} TL</p>
      <p>Delivery: ${deliveryFee} TL</p>
      <p>Service Fee: ${serviceFee} TL</p>
    `;

    document.getElementById("total").innerText = "Total: " + total + " TL";
  }
  

  async function placeOrder(){
    const token = getToken();
    if (!token) {
      alert("Sipariş vermek için giriş yapmalısınız");
      window.location.href = "/login?redirect=/checkout";
      return;
    }

    const name = document.getElementById("name").value.trim();
    const phone = document.getElementById("phone").value.trim();
    const address = document.getElementById("address").value.trim();
    const cart = getCart();

    if (cart.length === 0) {
      alert("Cart is empty!");
      return;
    }

    if (!name || !phone || !address) {
      alert("Please fill all fields");
      return;
    }

    const normalizedCart = cart.map((item) => ({
      _id: item._id,
      name: item.name || "Menu Item",
      price: Number(item.price) || 0,
      image: item.image || "",
      qty: Number(item.qty || item.quantity || 1),
    }));

    const subtotal = normalizedCart.reduce(
      (sum, item) => sum + item.price * item.qty,
      0
    );
    const totalPrice = subtotal + 40 + 10;

    try {
      const response = await fetch(API_URL, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": "Bearer " + token,
        },
        body: JSON.stringify({
          items: normalizedCart,
          totalPrice,
          deliveryAddress: address,
          phone,
        }),
      });

      if (response.status === 401) {
        alert("Sipariş vermek için giriş yapmalısınız");
        window.location.href = "/login?redirect=/checkout";
        return;
      }

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({}));
        alert(errorData.message || "Order could not be created");
        return;
      }

      localStorage.removeItem(CART_KEY);
      alert("Order placed successfully!");
      window.location.href = "/my-orders";
    } catch (error) {
      console.error(error);
      alert("Network error. Please try again.");
    }
  }

  loadSummary();
</script>

</body>
</html>
