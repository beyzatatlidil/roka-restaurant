<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login | Roka Restaurant</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>

<body>
  <main class="container" style="max-width: 500px; margin-top: 60px;">
    <h1>Login</h1>
    <div id="loginMessage"></div>

    <form id="loginForm">
      <div class="form-group" style="margin-bottom: 16px;">
        <label for="email">Email</label>
        <input type="email" id="email" required />
      </div>

      <div class="form-group" style="margin-bottom: 16px;">
        <label for="password">Password</label>
        <input type="password" id="password" required />
      </div>

      <button type="submit" class="btn btn-primary">Login</button>
    </form>
  </main>

  <script>ee
const loginForm = document.getElementById("loginForm");
const loginMessage = document.getElementById("loginMessage");

const redirectParam = new URLSearchParams(window.location.search).get("redirect");

function showMessage(type, text) {
  loginMessage.innerHTML = `
    <div style="
      padding: 12px;
      margin-bottom: 16px;
      border-radius: 8px;
      color: white;
      background: ${type === "success" ? "#16a34a" : "#dc2626"};
    ">
      ${text}
    </div>
  `;
}

loginForm.addEventListener("submit", async (e) => {
  e.preventDefault();

  const email = document.getElementById("email").value.trim();
  const password = document.getElementById("password").value.trim();

  if (!email || !password) {
    showMessage("error", "Please fill all fields");
    return;
  }

  try {
    const response = await fetch("/api/auth/login", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ email, password })
    });

    const result = await response.json();
    console.log("LOGIN RESULT:", result);

    if (!response.ok || !result.token) {
      localStorage.removeItem("token");
      throw new Error(result.message || "Login failed");
    }

    if (
      result.token === "undefined" ||
      result.token === "null" ||
      result.token.trim() === ""
    ) {
      localStorage.removeItem("token");
      throw new Error("Invalid token");
    }

    // SAVE
    localStorage.setItem("token", result.token);
    localStorage.setItem("user", JSON.stringify(result.user));

    showMessage("success", "Login successful. Redirecting...");

    setTimeout(() => {

      // 1️⃣ URL redirect
      if (redirectParam && redirectParam !== "null") {
        window.location.href = redirectParam;
        return;
      }

      // 2️⃣ Cart redirect
      const savedRedirect = localStorage.getItem("rokaRedirectAfterLogin");

      if (savedRedirect) {
        localStorage.removeItem("rokaRedirectAfterLogin");
        window.location.href = savedRedirect;
        return;
      }

      // 3️⃣ default
      window.location.href = "/";

    }, 800);

  } catch (error) {
    console.error("LOGIN ERROR:", error);
    showMessage("error", error.message || "Login failed");
  }
});
</script>
</body>

</html>
