<!DOCTYPE html>
<html>
<head>
  <title>Menu</title>

  <style>
    body {
      background: #0b0f1a;
      color: white;
      font-family: Arial;
      padding: 20px;
    }

    h1 {
      text-align: center;
      margin-bottom: 30px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: #111827;
      border-radius: 12px;
      padding: 15px;
      box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .card img {
      width: 100%;
      height: 150px;
      object-fit: cover;
      border-radius: 8px;
    }

    .name {
      font-size: 18px;
      font-weight: bold;
      margin-top: 10px;
    }

    .price {
      color: #f59e0b;
      margin-top: 5px;
    }

    .desc {
      font-size: 14px;
      color: #9ca3af;
      margin-top: 5px;
    }

    .btn {
      margin-top: 10px;
      width: 100%;
      padding: 10px;
      border-radius: 8px;
      border: none;
      background: #f59e0b;
      cursor: pointer;
      font-weight: bold;
    }
  </style>
</head>

<body>

<h1>Our Menu</h1>

<div class="grid">
  <% menuItems.forEach(item => { %>

    <div class="card">
      <img src="<%= item.image %>" />

      <div class="name"><%= item.name %></div>
      <div class="price"><%= item.price %> TL</div>
      <div class="desc"><%= item.description %></div>

      <button
  onclick="addToCart(this)"
  data-id="<%= item._id %>"
  data-name="<%= item.name %>"
  data-price="<%= item.price %>"
  data-image="<%= item.image %>"
>
  Add to Cart
</button>
    </div>

  <% }) %>
</div>

<script>
function addToCart(btn) {
  const CART_KEY = "rokaCart";

  let cart = [];

  try {
    cart = JSON.parse(localStorage.getItem(CART_KEY)) || [];
  } catch {
    cart = [];
  }

  const product = {
    _id: btn.dataset.id,
    name: btn.dataset.name,
    price: Number(btn.dataset.price) || 0,
    image: btn.dataset.image || "",
    qty: 1
  };

  const existing = cart.find(i => i._id === product._id);

  if (existing) {
    existing.qty += 1;
  } else {
    cart.push(product);
  }

  localStorage.setItem(CART_KEY, JSON.stringify(cart));

  alert("Added to cart ✅");
}
</script>

</body>
</html>
