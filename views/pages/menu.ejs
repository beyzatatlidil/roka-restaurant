<!DOCTYPE html>
<html lang="en">
<head>

<link rel="stylesheet" href="/css/chatbot.css" />

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Roka Restaurant | Menu</title>
  <style>
  
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f8f5f0;
      color: #222;
    }

    .navbar {
      background: #111827;
      color: white;
      padding: 18px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
    }

    .logo {
      font-size: 24px;
      font-weight: bold;
      letter-spacing: 1px;
    }

    .nav-links a {
      color: white;
      text-decoration: none;
      margin-left: 24px;
      font-size: 15px;
      font-weight: 600;
      transition: 0.3s;
    }

    .nav-links a:hover {
      color: #f59e0b;
    }

    .hero {
      background: linear-gradient(rgba(17,24,39,0.65), rgba(17,24,39,0.65)),
        url("https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&fit=crop&w=1400&q=80") center/cover;
      height: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: white;
      padding: 20px;
    }

    .hero-content h1 {
      font-size: 42px;
      margin-bottom: 12px;
    }

    .hero-content p {
      font-size: 18px;
      opacity: 0.95;
    }

    .container {
      width: 92%;
      max-width: 1250px;
      margin: 50px auto;
    }

    .section-title {
      text-align: center;
      margin-bottom: 35px;
    }

    .section-title h2 {
      font-size: 34px;
      margin-bottom: 10px;
      color: #111827;
    }

    .section-title p {
      color: #666;
      font-size: 16px;
    }

    .menu-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
      gap: 28px;
    }

    .menu-card {
      background: white;
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      transition: transform 0.25s ease, box-shadow 0.25s ease;
      display: flex;
      flex-direction: column;
    }

    .menu-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 14px 30px rgba(0,0,0,0.12);
    }

    .menu-image {
      width: 100%;
      height: 220px;
      object-fit: cover;
      display: block;
    }

    .menu-placeholder {
      width: 100%;
      height: 220px;
      background: #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #6b7280;
      font-size: 15px;
    }

    .menu-content {
      padding: 20px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .category-badge {
      display: inline-block;
      align-self: flex-start;
      background: #fef3c7;
      color: #92400e;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: bold;
      margin-bottom: 14px;
    }

    .menu-title {
      font-size: 22px;
      margin-bottom: 10px;
      color: #111827;
    }

    .menu-description {
      color: #555;
      line-height: 1.5;
      font-size: 15px;
      min-height: 68px;
      margin-bottom: 18px;
    }

    .menu-footer {
      margin-top: auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .price {
      font-size: 22px;
      font-weight: bold;
      color: #111827;
    }

    .add-btn {
      border: none;
      background: #111827;
      color: white;
      padding: 12px 16px;
      border-radius: 12px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 700;
      transition: 0.25s;
    }

    .add-btn:hover {
      background: #f59e0b;
      color: #111827;
    }

    .empty-box {
      background: white;
      border-radius: 18px;
      padding: 40px;
      text-align: center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      color: #666;
    }

    @media (max-width: 768px) {
      .navbar {
        padding: 16px 20px;
        flex-direction: column;
        gap: 10px;
      }

      .nav-links a {
        margin: 0 10px;
      }

      .hero {
        height: 220px;
      }

      .hero-content h1 {
        font-size: 32px;
      }

      .section-title h2 {
        font-size: 28px;
      }
    }
  </style>
</head>
<body>
  <header class="navbar">
    <div class="logo">ROKA</div>
    <nav class="nav-links">
      <a href="/">Home</a>
      <a href="/menu">Menu</a>
      <a href="/cart">Cart</a>
      <a href="/my-orders">My Orders</a>
      <a href="/reservation">Reservation</a>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-content">
      <h1>Discover Our Menu</h1>
      <p>Fresh flavors, quality ingredients, and a modern dining experience.</p>
    </div>
  </section>

  <main class="container">
    <div class="section-title">
      <h2>Popular Dishes</h2>
      <p>Choose your favorite meal and add it to your cart.</p>
    </div>

    <% if (!menuItems || menuItems.length === 0) { %>
      <div class="empty-box">
        <h3>No menu items yet</h3>
        <p>Products added by admin will appear here.</p>
      </div>
    <% } else { %>
      <div class="menu-grid">
        <% menuItems.forEach(item => { %>
          <div class="menu-card">
            <% if (item.image) { %>
              <img class="menu-image" src="<%= item.image %>" alt="<%= item.name %>">
            <% } else { %>
              <div class="menu-placeholder">No Image Available</div>
            <% } %>

            <div class="menu-content">
              <span class="category-badge"><%= item.category %></span>
              <h3 class="menu-title"><%= item.name %></h3>
              <p class="menu-description">
                <%= item.description || "A delicious choice prepared with quality ingredients." %>
              </p>

              <div class="menu-footer">
                <div class="price"><%= item.price %> TL</div>

                <button
                  class="add-btn"
                  data-id="<%= item._id %>"
                  data-name="<%= item.name %>"
                  data-price="<%= item.price %>"
                  data-image="<%= item.image || '' %>"
                  onclick="addToCart(this)"
                >
                  Add to Cart
                </button>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </main>

<script>
  function addToCart(item) {
  const cart = JSON.parse(localStorage.getItem("rokaCart")) || [];
  const product = {
    _id: item.dataset.id,
    name: item.dataset.name,
    price: Number(item.dataset.price) || 0,
    image: item.dataset.image || "",
    qty: 1,
  };

  const existing = cart.find((i) => i._id === product._id);

  if (existing) {
    existing.qty = Number(existing.qty || 0) + 1;
  } else {
    cart.push(product);
  }

  localStorage.setItem("rokaCart", JSON.stringify(cart));
  alert("Added to cart");
}
</script>
  
  <%- include("../partials/chatbot") %>
  
</body>
</html>
