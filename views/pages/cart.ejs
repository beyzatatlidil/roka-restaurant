<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Roka Restaurant | Cart</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body{
      background:#f7f7f7;
    }

    .navbar{
      background:#111;
      color:white;
      padding:18px 40px;
      display:flex;
      justify-content:space-between;
      align-items:center;
    }

    .navbar a{
      color:white;
      text-decoration:none;
      margin-left:20px;
      font-weight:bold;
    }

    .container{
      width:92%;
      max-width:1200px;
      margin:50px auto;
      display:grid;
      grid-template-columns:2fr 1fr;
      gap:24px;
      align-items:start;
    }

    h1{
      margin-bottom:25px;
    }

    .cart-box,
    .summary-box{
      background:white;
      padding:30px;
      border-radius:16px;
      box-shadow:0 8px 30px rgba(0,0,0,0.08);
    }

    .summary-box h2{
      margin-bottom:20px;
    }

    .summary-row,
    .summary-total{
      display:flex;
      justify-content:space-between;
      align-items:center;
      padding:14px 0;
      border-bottom:1px solid #eee;
    }

    .summary-total{
      font-size:24px;
      font-weight:bold;
      border-bottom:none;
      padding-top:22px;
    }

    .cart-item{
      display:flex;
      gap:15px;
      align-items:center;
      padding:18px 0;
      border-bottom:1px solid #eee;
    }

    .cart-image img{
      width:80px;
      height:80px;
      object-fit:cover;
      border-radius:10px;
    }

    .cart-info{
      flex:1;
    }

    .cart-right{
      text-align:right;
    }

    .quantity-box{
      display:flex;
      align-items:center;
      gap:10px;
      margin-top:8px;
    }

    .quantity-box button{
      width:28px;
      height:28px;
      border:none;
      background:#eee;
      border-radius:6px;
      cursor:pointer;
      font-weight:bold;
    }

    .quantity-box button:hover{
      background:#ddd;
    }

    .remove-btn{
      margin-top:6px;
      background:#d32f2f;
      color:white;
      border:none;
      padding:7px 12px;
      border-radius:6px;
      cursor:pointer;
    }

    .actions-column{
      display:flex;
      flex-direction:column;
      gap:12px;
      margin-top:20px;
    }

    .btn{
      border:none;
      padding:12px 16px;
      border-radius:8px;
      cursor:pointer;
      font-weight:bold;
      width:100%;
    }

    .clear{
      background:#444;
      color:white;
    }

    .checkout{
      background:#f59e0b;
      color:black;
    }

    .empty{
      text-align:center;
      color:#666;
      font-size:18px;
      padding:40px 0;
    }

    .modal-overlay{
      display:none;
      position:fixed;
      inset:0;
      background:rgba(0,0,0,0.6);
      justify-content:center;
      align-items:center;
      z-index:999;
    }

    .modal-box{
      background:white;
      padding:32px;
      border-radius:16px;
      width:360px;
      text-align:center;
      box-shadow:0 10px 40px rgba(0,0,0,0.25);
    }

    .modal-box h2{
      margin-bottom:10px;
    }

    .modal-box p{
      margin-bottom:22px;
      color:#555;
      line-height:1.4;
    }

    .modal-actions{
      display:flex;
      gap:10px;
      justify-content:center;
    }

    .modal-login{
      background:#f59e0b;
      border:none;
      padding:10px 18px;
      border-radius:8px;
      cursor:pointer;
      font-weight:bold;
    }

    .modal-cancel{
      background:#eee;
      border:none;
      padding:10px 18px;
      border-radius:8px;
      cursor:pointer;
    }

    @media(max-width:900px){
      .container{
        grid-template-columns:1fr;
      }
    }
  </style>
</head>

<body>

  <div class="navbar">
    <div><strong>ROKA Restaurant</strong></div>
    <div>
      <a href="/">Home</a>
      <a href="/menu">Menu</a>
      <a href="/cart">Cart</a>
    </div>
  </div>

  <div class="container">
    <div class="cart-box">
      <h1>Your Cart</h1>
      <div id="cart-container"></div>
    </div>

    <div class="summary-box">
      <h2>Order Summary</h2>

      <div class="summary-row">
        <span>Subtotal</span>
        <span id="subtotal">0 TL</span>
      </div>

      <div class="summary-row">
        <span>Delivery Fee</span>
        <span id="delivery-fee">0 TL</span>
      </div>

      <div class="summary-row">
        <span>Service Fee</span>
        <span id="service-fee">0 TL</span>
      </div>

      <div class="summary-total">
        <span>Total</span>
        <span id="cart-total">0 TL</span>
      </div>

      <div class="actions-column">
        <button class="btn clear" onclick="clearCart()">Clear Cart</button>
        <button class="btn checkout" onclick="goToCheckout()">Checkout</button>
      </div>
    </div>
  </div>

  <div id="loginModal" class="modal-overlay">
    <div class="modal-box">
      <h2>Login Required</h2>
      <p>You need to login before placing an order.</p>

      <div class="modal-actions">
        <button class="modal-login" onclick="goLogin()">Login</button>
        <button class="modal-cancel" onclick="closeModal()">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    const CART_KEY = "rokaCart";
    const API_URL = "/api/orders";

    function getCart() {
      try {
        return JSON.parse(localStorage.getItem(CART_KEY)) || [];
      } catch (error) {
        localStorage.removeItem(CART_KEY);
        return [];
      }
    }

    function saveCart(cart) {
      localStorage.setItem(CART_KEY, JSON.stringify(cart));
    }

    function getToken() {
      const token = localStorage.getItem("token");

      if (!token || token === "undefined" || token === "null") {
        return null;
      }

      return token;
    }

    function openModal() {
      document.getElementById("loginModal").style.display = "flex";
    }

    function closeModal() {
      document.getElementById("loginModal").style.display = "none";
    }

    function goLogin() {
      window.location.href = "/login?redirect=/cart";
    }

    function increaseQty(index) {
      const cart = getCart();

      if (!cart[index]) return;

      cart[index].qty = Number(cart[index].qty || cart[index].quantity || 1) + 1;
      saveCart(cart);
      renderCart();
    }

    function decreaseQty(index) {
      const cart = getCart();

      if (!cart[index]) return;

      const currentQty = Number(cart[index].qty || cart[index].quantity || 1);

      if (currentQty > 1) {
        cart[index].qty = currentQty - 1;
      } else {
        cart.splice(index, 1);
      }

      saveCart(cart);
      renderCart();
    }

    function removeItem(index) {
      const cart = getCart();

      if (!cart[index]) return;

      cart.splice(index, 1);
      saveCart(cart);
      renderCart();
    }

    function clearCart() {
      localStorage.removeItem(CART_KEY);
      renderCart();
    }

    function renderCart() {
      const cartContainer = document.getElementById("cart-container");
      const totalContainer = document.getElementById("cart-total");

      const cart = getCart();

      if (cart.length === 0) {
        cartContainer.innerHTML = '<div class="empty">Your cart is empty</div>';
        document.getElementById("subtotal").innerText = "0 TL";
        document.getElementById("delivery-fee").innerText = "0 TL";
        document.getElementById("service-fee").innerText = "0 TL";
        totalContainer.innerText = "0 TL";
        return;
      }

      let subtotal = 0;

      cartContainer.innerHTML = cart.map((item, index) => {
        const name = item.name || "Menu Item";
        const image = item.image || "/images/default-food.jpg";
        const price = Number(item.price) || 0;
        const qty = Number(item.qty || item.quantity) || 1;
        const itemTotal = price * qty;

        subtotal += itemTotal;

        return `
          <div class="cart-item">
            <div class="cart-image">
              <img src="${image}" alt="${name}" />
            </div>

            <div class="cart-info">
              <h3>${name}</h3>
              <p>${price} TL</p>

              <div class="quantity-box">
                <button onclick="decreaseQty(${index})">-</button>
                <span>${qty}</span>
                <button onclick="increaseQty(${index})">+</button>
              </div>
            </div>

            <div class="cart-right">
              <strong>${itemTotal} TL</strong>
              <br>
              <button class="remove-btn" onclick="removeItem(${index})">Remove</button>
            </div>
          </div>
        `;
      }).join("");

      const deliveryFee = 40;
      const serviceFee = 10;
      const grandTotal = subtotal + deliveryFee + serviceFee;

      document.getElementById("subtotal").innerText = subtotal + " TL";
      document.getElementById("delivery-fee").innerText = deliveryFee + " TL";
      document.getElementById("service-fee").innerText = serviceFee + " TL";
      totalContainer.innerText = grandTotal + " TL";
    }

    async function createOrder() {
      const token = getToken();
      const cart = getCart().map((item) => ({
        _id: item._id,
        name: item.name || "Menu Item",
        price: Number(item.price) || 0,
        image: item.image || "",
        qty: Number(item.qty || item.quantity) || 1,
      }));

      if (cart.length === 0) {
        alert("Your cart is empty!");
        return;
      }

      if (!token) {
        window.location.href = "/login?redirect=/cart";
        return;
      }

      const subtotal = cart.reduce((sum, item) => sum + item.price * item.qty, 0);
      const deliveryFee = 40;
      const serviceFee = 10;
      const totalPrice = subtotal + deliveryFee + serviceFee;


      try {
        const res = await fetch(API_URL, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + token
          },
          body: JSON.stringify({
            items: cart,
            totalPrice,
          })
        });

        if (res.status === 401) {
          openModal();
          return;
        }

        if (!res.ok) {
          const errorData = await res.json().catch(() => ({}));
          alert(errorData.message || "Order failed");
          return;
        }

        localStorage.removeItem(CART_KEY);
        window.location.href = "/my-orders";

      } catch (error) {
        console.error(error);
        alert("Network error. Please try again.");
      }
    }

    function goToCheckout() {
      createOrder();
    }

    renderCart();

    const params = new URLSearchParams(window.location.search);

    if (params.get("checkout") === "1") {
      window.history.replaceState({}, document.title, "/cart");
      createOrder();
    }
  </script>

</body>
</html>
