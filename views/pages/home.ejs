<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ROKA | Premium Dining</title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/chatbot.css" />

  <style>
    .nav-links a {
      position: relative;
      padding-bottom: 6px;
      transition: 0.3s;
    }

    .nav-links a::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 0;
      width: 0%;
      height: 2px;
      background: #d7a76c;
      transition: 0.3s;
    }

    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 100%;
    }

    .btn {
      transition: all 0.25s ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 28px rgba(215, 167, 108, 0.35);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
      transform: translateY(-2px);
    }

    .fade-in {
      opacity: 0;
      transform: translateY(28px);
      transition: all 0.7s ease;
    }

    .fade-in.show {
      opacity: 1;
      transform: translateY(0);
    }

    .home-hero {
      padding-top: 80px;
      padding-bottom: 70px;
    }

    .home-kicker {
      color: #d7a76c;
      font-weight: 800;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 16px;
      font-size: 14px;
    }

    .home-actions {
      margin-top: 26px;
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .luxury-panel {
      min-height: 540px;
      border-radius: 28px;
      overflow: hidden;
      position: relative;
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 30px 80px rgba(0,0,0,0.35);
    }

    .luxury-panel::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(8,10,14,0.88), rgba(8,10,14,0.08));
    }

    .luxury-card {
      position: absolute;
      left: 28px;
      right: 28px;
      bottom: 28px;
      z-index: 2;
      padding: 24px;
      border-radius: 22px;
      background: rgba(10, 12, 18, 0.62);
      border: 1px solid rgba(255,255,255,0.12);
      backdrop-filter: blur(18px);
    }

    .luxury-badge {
      display: inline-block;
      color: #d7a76c;
      border: 1px solid rgba(215,167,108,0.45);
      padding: 8px 14px;
      border-radius: 999px;
      font-weight: 700;
      margin-bottom: 14px;
    }

    .signature-section {
      margin-top: 40px;
      margin-bottom: 80px;
    }

    .signature-grid {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 26px;
      align-items: stretch;
    }

    .signature-card {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 26px;
      padding: 24px;
      overflow: hidden;
    }

    .signature-card img {
      width: 100%;
      height: 260px;
      object-fit: cover;
      border-radius: 20px;
      margin-bottom: 18px;
      filter: brightness(0.82);
    }

    .home-info-list {
      display: grid;
      gap: 18px;
    }

    @media (max-width: 900px) {
      .signature-grid {
        grid-template-columns: 1fr;
      }

      .luxury-panel {
        min-height: 420px;
      }
    }
  </style>
</head>

<body>
  <nav class="navbar">
    <div class="container navbar-inner">
      <div class="logo">Roka <span>Restaurant</span></div>

      <div class="nav-links">
        <a href="/" class="active">Home</a>
        <a href="/menu">Menu</a>
        <a href="/reservation">Reservation</a>
        <a href="/my-orders">My Orders</a>
        <a href="/my-reservations">My Reservations</a>
        <a href="/login">Login</a>
      </div>
    </div>
  </nav>

  <main class="container">
    <section class="hero home-hero">
      <div class="hero-grid">
        <div class="hero-text fade-in">
          <div class="home-kicker">Premium Dining House</div>

          <h1>Fine Dining, Crafted With Character.</h1>

          <p>
            Step into ROKA, where refined flavors, elegant interiors, and thoughtful service
            come together for a memorable dining experience.
          </p>

          <div class="home-actions">
            <a href="/menu" class="btn btn-primary">Explore Menu</a>
            <a href="/reservation" class="btn btn-secondary">Reserve a Table</a>
          </div>

          <div class="hero-stats">
            <div class="stat-card">
              <h3>Signature</h3>
              <p>Chef Selection</p>
            </div>

            <div class="stat-card">
              <h3>Elegant</h3>
              <p>Dining Room</p>
            </div>

            <div class="stat-card">
              <h3>Premium</h3>
              <p>Guest Service</p>
            </div>
          </div>
        </div>

        <div class="hero-visual fade-in">
          <div
            class="luxury-panel"
            style="
              background:
                linear-gradient(rgba(12,14,18,0.1), rgba(12,14,18,0.4)),
                url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&fit=crop&w=1400&q=90')
                center/cover no-repeat;
            "
          >
            <div class="luxury-card">
              <span class="luxury-badge">ROKA Experience</span>
              <h4>Designed for evenings that feel special.</h4>
              <p>
                Warm lighting, curated dishes, and a calm premium atmosphere from the first welcome.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="section-header fade-in">
      <div>
        <h2>Exquisite Cuisine</h2>
        <p>Modern dishes, rich presentation, and ingredients selected with care.</p>
      </div>
    </section>

    <section class="signature-section">
      <div class="signature-grid">
        <div class="signature-card fade-in">
          <img
            src="https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=1300&q=90"
            alt="Signature dish"
          />

          <h3>Chef’s Signature Plates</h3>
          <p>
            Our menu combines contemporary presentation with comforting flavors,
            creating plates that feel both refined and memorable.
          </p>

          <br />
          <a href="/menu" class="btn btn-primary">View Full Menu</a>
        </div>

        <div class="home-info-list">
          <div class="info-box fade-in">
            <h4>Atmosphere</h4>
            <p>
              A dark, elegant interior with warm accents designed for dates,
              celebrations, and relaxed premium dinners.
            </p>
          </div>

          <div class="info-box fade-in">
            <h4>Reservation Flow</h4>
            <p>
              Choose your date, time, guest count, and special request with a clean booking experience.
            </p>
          </div>

          <div class="info-box fade-in">
            <h4>Guest Focus</h4>
            <p>
              From arrival to final service, ROKA is built around comfort, timing, and detail.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <p>© 2026 Roka Restaurant — Premium dining experience.</p>
    </div>
  </footer>

  <script>
    const elements = document.querySelectorAll(".fade-in");

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("show");
        }
      });
    });

    elements.forEach((el) => observer.observe(el));
  </script>
</body>
</html>
