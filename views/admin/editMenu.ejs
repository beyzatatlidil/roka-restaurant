<%- include('../partials/header') %>
  <!DOCTYPE html>
  <html>

  <head>
    <title>Edit Menu Item</title>
    <style>
      body {
        background: #0b0f1a;
        color: white;
        font-family: Arial;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .card {
        background: #111827;
        padding: 30px;
        border-radius: 12px;
        width: 400px;
        box-shadow: 0 0 20px rgba(0, 0, 0, 0.6);
      }

      h1 {
        text-align: center;
        margin-bottom: 20px;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 10px;
        margin-bottom: 12px;
        border-radius: 8px;
        border: none;
        outline: none;
      }

      textarea {
        height: 80px;
        resize: none;
      }

      button {
        width: 100%;
        padding: 12px;
        background: #3b82f6;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        color: white;
      }

      button:hover {
        background: #2563eb;
      }

      .back {
        display: block;
        margin-top: 15px;
        text-align: center;
        color: #9ca3af;
        text-decoration: none;
      }

      .back:hover {
        color: white;
      }

      img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 10px;
      }
    </style>
  </head>

  <body>

    <div class="card">
      <h1>Edit Menu Item</h1>

      <img id="preview" src="<%= menuItem.image %>" />

      <form action="/admin/menu/edit/<%= menuItem._id %>" method="POST">
        <input type="text" name="name" value="<%= menuItem.name %>" required />

        <textarea name="description"><%= menuItem.description %></textarea>

        <input type="number" name="price" value="<%= menuItem.price %>" required />

        <select name="category" required>
          <option value="Burger" <%=menuItem.category==="Burger" ? "selected" : "" %>>Burger</option>
          <option value="Pizza" <%=menuItem.category==="Pizza" ? "selected" : "" %>>Pizza</option>
          <option value="Pasta" <%=menuItem.category==="Pasta" ? "selected" : "" %>>Pasta</option>
          <option value="Salad" <%=menuItem.category==="Salad" ? "selected" : "" %>>Salad</option>
          <option value="Dessert" <%=menuItem.category==="Dessert" ? "selected" : "" %>>Dessert</option>
          <option value="Drink" <%=menuItem.category==="Drink" ? "selected" : "" %>>Drink</option>
        </select>

        <input id="imageInput" type="text" name="image" value="<%= menuItem.image %>" />

        <button type="submit">Update Item</button>
      </form>

      <a href="/admin/menu" class="back">← Back to Menu</a>
    </div>

    <script>
      const input = document.getElementById("imageInput");
      const preview = document.getElementById("preview");

      const updateImage = () => {
        preview.src = input.value;
      };

      input.addEventListener("input", updateImage);
      input.addEventListener("change", updateImage);
    </script>

  </body>

  </html>