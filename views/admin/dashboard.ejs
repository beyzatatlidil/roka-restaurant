<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin | Dashboard</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #f5f7fb;
      color: #1f2937;
    }

    .sidebar {
      width: 240px;
      height: 100vh;
      background: #111827;
      color: white;
      position: fixed;
      left: 0;
      top: 0;
      padding: 30px 20px;
    }

    .sidebar h2 {
      font-size: 24px;
      margin-bottom: 35px;
      text-align: center;
    }

    .sidebar a {
      display: block;
      color: #d1d5db;
      text-decoration: none;
      padding: 14px 16px;
      border-radius: 10px;
      margin-bottom: 10px;
      transition: 0.25s;
      font-weight: bold;
    }

    .sidebar a:hover,
    .sidebar a.active {
      background: #f59e0b;
      color: #111827;
    }

    .main {
      margin-left: 240px;
      padding: 35px;
    }

    .topbar h1 {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .topbar p {
      color: #6b7280;
      margin-bottom: 30px;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    .card h3 {
      color: #6b7280;
      font-size: 15px;
      margin-bottom: 12px;
    }

    .number {
      font-size: 34px;
      font-weight: bold;
      color: #111827;
    }

    @media (max-width: 900px) {
      .sidebar {
        position: static;
        width: 100%;
        height: auto;
      }

      .main {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <aside class="sidebar">
    <h2>ROKA Admin</h2>
    <a href="/admin" class="active">Dashboard</a>
    <a href="/admin/orders">Orders</a>
    <a href="/admin/reservations">Reservations</a>
    <a href="/admin/menu">Menu</a>
  </aside>

  <main class="main">
    <div class="topbar">
      <h1>Dashboard</h1>
      <p>Overview of your restaurant management system.</p>
    </div>

    <div class="cards">
      <div class="card">
        <h3>Users</h3>
        <div class="number"><%= userCount %></div>
      </div>

      <div class="card">
        <h3>Orders</h3>
        <div class="number"><%= orderCount %></div>
      </div>

      <div class="card">
        <h3>Reservations</h3>
        <div class="number"><%= reservationCount %></div>
      </div>

      <div class="card">
        <h3>Menu Items</h3>
        <div class="number"><%= menuCount %></div>
      </div>
    </div>
  </main>

</body>
</html>
