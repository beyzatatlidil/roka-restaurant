    cursor: pointer;
  }
</style>

<div class="chat-container" id="chatBox">
  <div class="chat-header">
    Roka Assistant
    <span onclick="toggleChat()" style="cursor:pointer;">✖</span>
  </div>

  <div class="chat-messages" id="messages"></div>

  <div class="chat-input">
    <textarea id="chatInput" rows="1" placeholder="Mesaj yaz..."></textarea>
    <button onclick="sendMessage()">Gönder</button>
  </div>
</div>

<!-- FLOAT BUTTON -->
<div onclick="toggleChat()" style="
position: fixed;
bottom: 20px;
right: 20px;
background: #f59e0b;
width: 65px;
height: 65px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
cursor: pointer;
font-size: 26px;
box-shadow: 0 10px 25px rgba(0,0,0,0.4);
">
  💬
</div>

<script>
  const messages = document.getElementById("messages");
  const input = document.getElementById("chatInput");

  /* TOGGLE */
  function toggleChat() {
    const chat = document.getElementById("chatBox");
    chat.style.display =
      chat.style.display === "flex" ? "none" : "flex";
  }

  /* ADD MESSAGE */
  function addMessage(text, type) {
    const div = document.createElement("div");
    div.className = "msg " + type;
    div.innerText = text;
    messages.appendChild(div);

    saveMessage(text, type);
    scrollBottom();
  }

  /* SCROLL */
  function scrollBottom() {
    messages.scrollTop = messages.scrollHeight;
  }

  /* TYPING */
  function showTyping() {
    const div = document.createElement("div");
    div.className = "msg bot";
    div.id = "typing";
    div.innerText = "...";
    messages.appendChild(div);
    scrollBottom();
  }

  function removeTyping() {
    const t = document.getElementById("typing");
    if (t) t.remove();
  }

  /* ENTER SEND */
  input.addEventListener("keydown", function (e) {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  /* LOCAL STORAGE */
  function saveMessage(text, type) {
    const chat = JSON.parse(localStorage.getItem("rokaChat")) || [];
    chat.push({ text, type });
    localStorage.setItem("rokaChat", JSON.stringify(chat));
  }

  function loadMessages() {
    const chat = JSON.parse(localStorage.getItem("rokaChat")) || [];
    chat.forEach(m => addMessage(m.text, m.type));
  }

  /* SEND */
  async function sendMessage() {
    const text = input.value.trim();
    if (!text) return;

    addMessage(text, "user");
    input.value = "";

    showTyping();

    try {
      const res = await fetch("/api/chat", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({ message: text })
      });

      const data = await res.json();

      removeTyping();
      addMessage(data.reply || "Cevap alınamadı", "bot");

    } catch (err) {
      removeTyping();
      addMessage("⚠️ Sunucuya bağlanılamıyor", "bot");
    }
  }

  /* INIT */
  loadMessages();
</script>
```