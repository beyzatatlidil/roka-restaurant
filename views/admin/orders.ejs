<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin | Orders</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body {
      background: #f5f7fb;
      color: #1f2937;
    }

    .sidebar {
      width: 240px;
      height: 100vh;
      background: #111827;
      color: white;
      position: fixed;
      left: 0;
      top: 0;
      padding: 30px 20px;
    }

    .sidebar h2 {
      font-size: 24px;
      margin-bottom: 35px;
      text-align: center;
    }

    .sidebar a {
      display: block;
      color: #d1d5db;
      text-decoration: none;
      padding: 14px 16px;
      border-radius: 10px;
      margin-bottom: 10px;
      transition: 0.25s;
      font-weight: bold;
    }

    .sidebar a:hover,
    .sidebar a.active {
      background: #f59e0b;
      color: #111827;
    }

    .main {
      margin-left: 240px;
      padding: 35px;
    }

    .topbar h1 {
      font-size: 32px;
      margin-bottom: 8px;
    }

    .topbar p {
      color: #6b7280;
      margin-bottom: 30px;
    }

    .table-card {
      background: white;
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    th, td {
      padding: 16px;
      text-align: left;
      border-bottom: 1px solid #eee;
      vertical-align: middle;
    }

    thead {
      background: #f9fafb;
    }

    .empty-box {
      padding: 40px;
      text-align: center;
      color: #6b7280;
    }

    .status-badge {
      display: inline-block;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: bold;
      text-transform: capitalize;
    }

    .pending {
      background: #fef3c7;
      color: #92400e;
    }

    .preparing {
      background: #dbeafe;
      color: #1d4ed8;
    }

    .out-for-delivery {
      background: #ede9fe;
      color: #6d28d9;
    }

    .delivered {
      background: #dcfce7;
      color: #166534;
    }

    .cancelled {
      background: #fee2e2;
      color: #991b1b;
    }

    .status-form {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .status-form select {
      padding: 8px 10px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      background: white;
      cursor: pointer;
    }

    .status-form button {
      padding: 8px 12px;
      border: none;
      border-radius: 8px;
      background: #111827;
      color: white;
      cursor: pointer;
      font-weight: bold;
    }

    .status-form button:hover {
      background: #f59e0b;
      color: #111827;
    }

    @media (max-width: 900px) {
      .sidebar {
        position: static;
        width: 100%;
        height: auto;
      }

      .main {
        margin-left: 0;
      }
    }
  </style>
</head>
<body>

  <aside class="sidebar">
    <h2>ROKA Admin</h2>
    <a href="/admin">Dashboard</a>
    <a href="/admin/orders" class="active">Orders</a>
    <a href="/admin/reservations">Reservations</a>
    <a href="/admin/menu">Menu</a>
  </aside>

  <main class="main">
    <div class="topbar">
      <h1>Orders</h1>
      <p>Track and manage incoming customer orders.</p>
    </div>

    <div class="table-card">
      <% if (!orders || orders.length === 0) { %>
        <div class="empty-box">
          <h3>No orders found</h3>
          <p>New customer orders will appear here.</p>
        </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Total Price</th>
              <th>Status</th>
              <th>Address</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <tr>
                <td><%= order.totalPrice || 0 %> TL</td>

                <td>
                  <span class="status-badge
                    <%= order.status === 'pending' ? 'pending' : '' %>
                    <%= order.status === 'preparing' ? 'preparing' : '' %>
                    <%= order.status === 'out for delivery' ? 'out-for-delivery' : '' %>
                    <%= order.status === 'delivered' ? 'delivered' : '' %>
                    <%= order.status === 'cancelled' ? 'cancelled' : '' %>">
                    <%= order.status || "pending" %>
                  </span>
                </td>

                <td><%= order.deliveryAddress || "No Address" %></td>

                <td>
                  <form action="/admin/orders/<%= order._id %>/status" method="POST" class="status-form">
                    <select name="status">
                      <option value="pending" <%= order.status === "pending" ? "selected" : "" %>>Pending</option>
                      <option value="preparing" <%= order.status === "preparing" ? "selected" : "" %>>Preparing</option>
                      <option value="out for delivery" <%= order.status === "out for delivery" ? "selected" : "" %>>Out for Delivery</option>
                      <option value="delivered" <%= order.status === "delivered" ? "selected" : "" %>>Delivered</option>
                      <option value="cancelled" <%= order.status === "cancelled" ? "selected" : "" %>>Cancelled</option>
                    </select>
                    <button type="submit">Update</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </main>

</body>
</html>
